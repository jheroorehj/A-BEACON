# ─── Gemini AI ───────────────────────────────────────────────────────────────
# AI Studio에서 자동 주입되거나 직접 발급한 키를 입력
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# ─── 서버 설정 ────────────────────────────────────────────────────────────────
# 앱이 배포된 URL (Cloud Run 자동 주입)
APP_URL="MY_APP_URL"

# CORS 허용 오리진 (콤마로 구분, 기본값: localhost 개발 포트)
ALLOWED_ORIGINS="http://localhost:5173,http://localhost:3000"

# ─── 클라이언트 환경 변수 (VITE_ 접두사 필수) ──────────────────────────────
# 실제 백엔드 API 주소. 공란이면 상대경로(/api/...) 사용
VITE_API_BASE_URL=""

# 데모 로그인 이메일 (인증 도입 전 임시값)
VITE_DEMO_EMAIL="guest@a-beacon.art"

# 데모 작가 ID (인증 도입 전 임시값)
VITE_DEMO_ARTIST_ID="artist_1"
